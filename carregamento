-- FAST LOAD
-----------------------------------------------------
local function fastLoad(url)
    local successHttp, source = pcall(function()
        return game:HttpGet(url)
    end)

    if not successHttp or not source then
        warn("[KitK4t Hub] Falha ao carregar:", url)
        return
    end

    local successRun, err = pcall(function()
        loadstring(source)()
    end)

    if not successRun then
        warn("[KitK4t Hub] Erro ao executar script:", err)
    end
end

