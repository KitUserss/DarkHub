-----------------------------------------------------
-- DECODIFICADOR BASE64 SIMPLES
-----------------------------------------------------

local function base64Decode(data)
    local b64 = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/"
    data = string.gsub(data, "[^"..b64.."=]", "")
    
    local result = ""
    for i = 1, #data, 4 do
        local chunk = data:sub(i, i+3)
        local n = 0
        for j = 1, 4 do
            local c = chunk:sub(j, j)
            if c == "=" then 
                n = n * 64
            else
                local pos = string.find(b64, c, 1, true)
                if pos then
                    n = n * 64 + (pos - 1)
                end
            end
        end
        
        local bytes = string.char(
            math.floor(n / 0x10000) % 0x100,
            math.floor(n / 0x100) % 0x100,
            n % 0x100
        )
        
        -- Remove bytes extras se tiver padding
        local pad = string.match(data, "=+$")
        if pad then
            local pcount = #pad
            bytes = bytes:sub(1, 4 - pcount)
        end
        
        result = result .. bytes
    end
    
    return result
end

